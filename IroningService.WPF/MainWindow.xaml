<Window x:Class="IroningService.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Moje Narudžbe" Height="450" Width="800">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="10">
            <Button Name="btnNovaNarudzba" 
                    Content="Nova narudžba" 
                    Click="btnNovaNarudzba_Click" 
                    Width="120" Margin="0,0,10,0"/>
            
            <Button Name="btnOdjava" 
                    Content="Odjava" 
                    Width="120"/>
        </StackPanel>

        <DataGrid x:Name="MyDataGrid" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" 
                  Grid.Row="1" 
                  Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Datum" Binding="{Binding DatumNarudzbe}" Width="Auto" />
                <DataGridTextColumn Header="Adresa" Binding="{Binding Adresa}" Width="*" />
                <DataGridCheckBoxColumn Header="Dostava" Binding="{Binding PotrebnaDostava}" Width="Auto" />
                
                <DataGridTemplateColumn Header="Akcije" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Vertical">
                                <Button Content="Pregled" Click="BtnPregled_Click" Margin="0,0,0,2"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>