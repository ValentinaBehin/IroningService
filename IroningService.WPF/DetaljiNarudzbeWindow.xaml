<Window x:Class="IroningService.WPF.DetaljiNarudzbeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detalji narudžbe" Height="500" Width="400" WindowStartupLocation="CenterOwner">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <Button Name="btnOtvoriRecenziju" 
                    Content="Ocijeni ovu narudžbu" 
                    Click="BtnOtvoriRecenziju_Click" 
                    Background="LightBlue" 
                    Margin="0,0,0,15"/>

            <TextBlock Text="Pregled narudžbe" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Datum: " FontWeight="Bold"/>
                <TextBlock Text="{Binding DatumNarudzbe, StringFormat='dd.MM.yyyy HH:mm'}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Adresa: " FontWeight="Bold"/>
                <TextBlock Text="{Binding Adresa}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Dostava potrebna: " FontWeight="Bold"/>
                <CheckBox IsChecked="{Binding PotrebnaDostava}" IsEnabled="False"/>
            </StackPanel>

            <TextBlock Text="Stavke:" FontWeight="Bold" Margin="0,15,0,5"/>
            
            <ListBox ItemsSource="{Binding Stavke}" Height="150" Margin="0,5,0,10" Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Foreground="Black" FontWeight="Bold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} (x{1})">
                                        <Binding Path="Usluga.Naziv" />
                                        <Binding Path="Kolicina" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Margin="0,10">
                <TextBlock Text="Recenzija:" FontWeight="Bold" />
                <TextBlock x:Name="txtRecenzijaPrikaz" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
                <TextBlock Text="Ukupno: " FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="{Binding UkupnaCijena, StringFormat='{}{0:F2} €'}" 
                           FontSize="16" FontWeight="Bold" Foreground="DarkGreen"/>
            </StackPanel>

            <Button Content="Zatvori" Click="BtnZatvori_Click" Margin="0,10,0,0" Width="100"/>
        </StackPanel>
    </ScrollViewer>
</Window>