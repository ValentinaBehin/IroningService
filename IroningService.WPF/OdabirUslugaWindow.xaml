<Window x:Class="IroningService.WPF.OdabirUslugaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Odabir Usluga" Height="600" Width="400"
        >
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Molim vas odaberite vrstu dostave:" FontWeight="Bold" Margin="0,0,0,5"/>
            
            <CheckBox Name="chkPrikup" Content="Prikup u Pegleraj" />
            <CheckBox Name="chkDostava" Content="Potrebna dostava" />

            <StackPanel Name="pnlAdresa" Margin="0,10,0,10"
                        Visibility="{Binding ElementName=chkDostava, Path=IsChecked, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Unesite adresu:" />
                <TextBox Name="txtAdresa" />
            </StackPanel>

            <TextBlock Text="Odaberite usluge:" FontWeight="Bold" Margin="0,10,0,10"/>
            
            <ItemsControl Name="icUsluge">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <CheckBox Name="chkUsluga" Content="{Binding Naziv}" Width="200" 
                                      VerticalAlignment="Center" Checked="Izracunaj_Event" Unchecked="Izracunaj_Event"/>
                            
                            <TextBlock Text="{Binding Cijena, StringFormat='{}{0:F2} €'}" 
                                       FontWeight="Bold" Foreground="DarkGreen" Width="60" VerticalAlignment="Center"/>

                            <StackPanel Name="pnlKolicina" Orientation="Horizontal" Visibility="Collapsed">
                                <TextBlock Text="Količina:" Margin="10,0,5,0" VerticalAlignment="Center"/>
                                <TextBox Name="txtKolicina" Width="40" Text="1" VerticalAlignment="Center" 
                                         TextChanged="Izracunaj_Event"/>
                            </StackPanel>
                        </StackPanel>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding ElementName=chkUsluga, Path=IsChecked}" Value="True">
                                <Setter TargetName="pnlKolicina" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Separator Margin="0,15,0,15"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Ukupna cijena: " FontWeight="Bold" FontSize="16"/>
                <TextBlock Name="txtUkupnaCijena" Text="0.00 €" FontWeight="Bold" FontSize="16" Foreground="DarkGreen"/>
            </StackPanel>

            <Button Name="btnSpremi" Content="Potvrdi odabir" Click="BtnSpremi_Click" Margin="0,20,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Window>