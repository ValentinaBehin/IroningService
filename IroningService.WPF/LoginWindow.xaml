<Window x:Class="IroningService.WPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prijava" Height="450" Width="400" WindowStartupLocation="CenterScreen">

    <Grid>
        <Image Source="logo.png" 
       Width="100" 
       Height="100" 
       HorizontalAlignment="Left" 
       VerticalAlignment="Top" 
       Margin="20" />

        <StackPanel Margin="20,100,20,20" VerticalAlignment="Top">
            <TextBlock Text="Email:" Margin="0,0,0,5"/>
            <TextBox x:Name="txtEmail" Height="30"/>
            
            <TextBlock Text="Lozinka:" Margin="0,10,0,5"/>
            <PasswordBox x:Name="txtLozinka" Height="30"/>
            
            <Button x:Name="btnPrijava" Content="Prijava" Margin="0,20,0,10" Height="40" Click="BtnPrijava_Click"/>
            <Button x:Name="btnRegistracija" Content="Nemaš račun? Registriraj se" Click="BtnRegistracija_Click" />
        </StackPanel>
    </Grid>
</Window>