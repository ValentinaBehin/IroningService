<Window x:Class="IroningService.WPF.NaplataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Naplata" Height="300" Width="400" WindowStartupLocation="CenterScreen">
    
    <Grid>
       <StackPanel Margin="20" VerticalAlignment="Center">
    <TextBlock Text="Ukupan iznos za platiti: 25.00 EUR" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
    
    <Button x:Name="btnPlatiPayPal" Content="Plati putem PayPal-a" Height="50" Background="#0070ba" Foreground="White" Click="BtnPlatiPayPal_Click" Margin="0,0,0,10"/>
    
    <Button x:Name="btnPlatiKarticom" Content="Plati putem kreditne kartice" Height="50" Background="#4CAF50" Foreground="White" Click="BtnPlatiKarticom_Click" Margin="0,0,0,10"/>
    
    <Button x:Name="btnOznaciPlaceno" Content="Označi kao plaćeno" Height="50" Background="Gray" Foreground="White" Click="BtnOznaciPlaceno_Click"/>
</StackPanel>
    </Grid>
</Window>