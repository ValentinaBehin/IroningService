<Window x:Class="IroningService.WPF.RegistracijaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registracija" Height="400" Width="350" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="Ime:"/>
        <TextBox x:Name="txtIme" Margin="0,0,0,10"/>
        
        <TextBlock Text="Prezime:"/>
        <TextBox x:Name="txtPrezime" Margin="0,0,0,10"/>
        
        <TextBlock Text="Email:"/>
        <TextBox x:Name="txtEmail" Margin="0,0,0,10"/>
        
        <TextBlock Text="Lozinka:"/>
        <PasswordBox x:Name="txtLozinka" Margin="0,0,0,20"/>
        
        <Button Content="Registriraj se" Height="40" Click="BtnRegistriraj_Click" Background="LightBlue"/>
    </StackPanel>
</Window>