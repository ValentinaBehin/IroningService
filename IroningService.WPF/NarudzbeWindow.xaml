<StackPanel Margin="10">
    <DockPanel Margin="0,0,0,10">
        <Button Content="Nova narudžba" Click="BtnNovaNarudzba_Click" DockPanel.Dock="Left" Padding="10,5" />
        <Button Content="Odjava" Click="BtnOdjava_Click" DockPanel.Dock="Right" Padding="10,5" />
    </DockPanel>

    <DataGrid x:Name="dgNarudzbe" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
        <DataGrid.Columns>
            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
            <DataGridTextColumn Header="Datum narudžbe" Binding="{Binding DatumNarudzbe}" Width="*" />
            <DataGridTextColumn Header="Termin dostave" Binding="{Binding TerminDostave}" Width="*" />
            <DataGridTextColumn Header="Adresa" Binding="{Binding Adresa}" Width="*" />
            <DataGridTextColumn Header="Ukupno (€)" Binding="{Binding UkupnaCijena}" Width="80" />
            
            <DataGridTemplateColumn Header="Akcija" Width="Auto">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <Button Content="Ponovi narudžbu" Click="BtnPonovi_Click" Padding="5,2" />
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
        </DataGrid.Columns>
    </DataGrid>
</StackPanel>