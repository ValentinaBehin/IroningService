<Window x:Class="IroningService.WPF.NarudzbeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Moje Narudžbe" Height="450" Width="800">

    <StackPanel Margin="10">
        <DockPanel Margin="0,0,0,10">
            <Button Content="Nova narudžba" Click="BtnNovaNarudzba_Click" DockPanel.Dock="Left" Padding="10,5" />
            <Button Content="Odjava" Click="BtnOdjava_Click" DockPanel.Dock="Right" Padding="10,5" />
        </DockPanel>

        <DataGrid x:Name="dgNarudzbe" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Height="350">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Datum" Binding="{Binding DatumNarudzbe, StringFormat='dd.MM.yyyy HH:mm'}" Width="120"/>
                <DataGridTextColumn Header="Adresa" Binding="{Binding Adresa}" Width="200"/>
                <DataGridCheckBoxColumn Header="Dostava" Binding="{Binding PotrebnaDostava}" Width="60"/>
                
                <DataGridTemplateColumn Header="Usluge" Width="*">
    <DataGridTemplateColumn.CellTemplate>
        <DataTemplate>
            <ListBox ItemsSource="{Binding Stavke}" BorderThickness="0" Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Foreground="Black" FontWeight="Bold" Margin="2,0">
    <TextBlock.Text>
        <MultiBinding StringFormat="{}{0}: {1} kom.">
            <Binding Path="Usluga.Naziv" />
            <Binding Path="Kolicina" />
        </MultiBinding>
    </TextBlock.Text>
</TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DataTemplate>
    </DataGridTemplateColumn.CellTemplate>
</DataGridTemplateColumn>
<DataGridTemplateColumn Header="Akcije" Width="80">
    <DataGridTemplateColumn.CellTemplate>
        <DataTemplate>
            <Button Content="Pregled" 
                    Click="BtnPregled_Click" 
                    Padding="5,2" />
        </DataTemplate>
    </DataGridTemplateColumn.CellTemplate>
</DataGridTemplateColumn>

                <DataGridTextColumn Header="Ukupno" Binding="{Binding UkupnaCijena, StringFormat='{}{0:F2} €'}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</Window>