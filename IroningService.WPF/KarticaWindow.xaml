<Window x:Class="IroningService.WPF.KarticaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Plaćanje karticom" Height="350" Width="400" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="Molimo unesite podatke kartice" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>
        
        <TextBlock Text="Broj kartice:"/>
        <TextBox Height="30" Margin="0,0,0,10"/>
        
        <StackPanel Orientation="Horizontal">
            <StackPanel Width="150" Margin="0,0,20,0">
                <TextBlock Text="Datum isteka:"/>
                <TextBox Height="30"/>
            </StackPanel>
            <StackPanel Width="100">
                <TextBlock Text="CVC:"/>
                <TextBox Height="30"/>
            </StackPanel>
        </StackPanel>
        
        <Button Content="Potvrdi plaćanje" Height="40" Margin="0,30,0,0" Background="#4CAF50" Foreground="White" Click="BtnPotvrdi_Click"/>
    </StackPanel>
</Window>